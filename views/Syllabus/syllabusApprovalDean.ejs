<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Approve Syllabus — Dean</title>

    <!-- School palette variables -->
    <link rel="stylesheet" href="/common/css/variables.css">
    <!-- Material icons -->
    <link rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" />
    <!-- Approval detail page styles -->
    <link rel="stylesheet" href="/Syllabus/css/syllabusApprovalDetail.css">
</head>

<body data-user-role="dean">

    <main class="approval-detail-main">
        <div class="background-overlay"></div>

        <!-- ═══════════════════════════════════════════════════════════
             HEADER BAR — Course Info + School Logo
        ═══════════════════════════════════════════════════════════ -->
        <header class="approval-detail-header">
            <div class="ad-header-logo">
                <img src="/common/img/schoolLogo.png" alt="School Logo">
            </div>
            <div class="ad-header-divider"></div>
            <div class="ad-header-info">
                <h1 class="ad-course-name">
                    <%= locals.courseName || '[COURSE NAME]' %>
                </h1>
                <p class="ad-course-meta">
                    <span class="meta-item">
                        <%= locals.courseCode || '[COURSE CODE]' %>
                    </span>
                    <span class="ad-meta-divider">|</span>
                    <span class="meta-item">
                        <%= locals.courseSection || '[COURSE SECTION]' %>
                    </span>
                    <span class="ad-meta-divider">|</span>
                    <span class="meta-item">
                        <%= locals.academicYear || '[ACADEMIC YEAR]' %>
                    </span>
                </p>
            </div>
        </header>

        <!-- ═══════════════════════════════════════════════════════════
             BODY LAYOUT — Left (Document) + Right (Sidebar Panel)
        ═══════════════════════════════════════════════════════════ -->
        <div class="approval-detail-body">

            <!-- ─── LEFT: Document Preview ──────────────────────────── -->
            <section class="ad-document-panel">

                <!-- Back button -->
                <a href="/syllabus/approve" class="ad-back-btn">
                    <span class="material-symbols-outlined">arrow_back</span> BACK
                </a>

                <div class="ad-file-type-badge">
                    <%= locals.fileType || '[FILE TYPE]' %>
                </div>

                <h2 class="ad-section-title">Basic Information</h2>

                <!-- ── Document Read-Only Preview ── -->
                <div class="ad-document-preview ad-doc-content">
                    
                    <h3 class="ad-section-heading">Course Details</h3>
                    <table class="ad-data-table ad-data-table-wide">
                        <tr><td style="font-weight:bold; width: 30%; background:#f9f9f9;">Course Code</td><td><%= locals.courseCode %></td></tr>
                        <tr><td style="font-weight:bold; background:#f9f9f9;">Course Title</td><td><%= locals.courseName %></td></tr>
                        <tr><td style="font-weight:bold; background:#f9f9f9;">Section</td><td><%= locals.courseSection %></td></tr>
                        <tr><td style="font-weight:bold; background:#f9f9f9;">Academic Year</td><td><%= locals.academicYear %></td></tr>
                    </table>

                    <h3 class="ad-section-heading">Program Educational Objectives (PEO)</h3>
                    <% if (locals.peos && locals.peos.length > 0 && locals.peos[0].description) { %>
                        <table class="ad-data-table">
                            <thead>
                                <tr>
                                    <th style="width:10%; text-align: center;">PEO</th>
                                    <th style="text-align: left;">Description</th>
                                    <th style="width:20%; text-align: center;">Mission Mapping</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% locals.peos[0].description.forEach(function(desc, index) { 
                                     const rating = locals.peos[0].rating && locals.peos[0].rating[index];
                                %>
                                    <tr>
                                        <td style="font-weight:bold; text-align:center;"><%= index + 1 %></td>
                                        <td><%= desc %></td>
                                        <td style="text-align:center;">
                                            <% if (rating && rating.length === 3) { %>
                                                <%= (rating[0]==='1'?'A ':'') + (rating[1]==='1'?'B ':'') + (rating[2]==='1'?'C':'') || '-' %>
                                            <% } else { %>
                                                <%= rating || '-' %>
                                            <% } %>
                                        </td>
                                    </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    <% } else { %>
                        <p class="ad-no-content">No program educational objectives provided.</p>
                    <% } %>

                    <h3 class="ad-section-heading">Student Outcomes (SO)</h3>
                    <% if (locals.seos && locals.seos.length > 0 && locals.seos[0].description) { %>
                        <table class="ad-data-table">
                            <thead>
                                <tr>
                                    <th style="width:10%; text-align: center;">SO</th>
                                    <th style="text-align: left;">Description</th>
                                    <th style="width:20%; text-align: center;">PEO Mapping</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% locals.seos[0].description.forEach(function(desc, index) { 
                                     const rating = locals.seos[0].rating && locals.seos[0].rating[index];
                                     const letter = String.fromCharCode(97 + index);
                                %>
                                    <tr>
                                        <td style="font-weight:bold; text-align:center;"><%= letter %></td>
                                        <td><%= desc %></td>
                                        <td style="text-align:center;">
                                            <% if (rating && rating.length === 3) { %>
                                                <%= (rating[0]==='1'?'1 ':'') + (rating[1]==='1'?'2 ':'') + (rating[2]==='1'?'3':'') || '-' %>
                                            <% } else { %>
                                                <%= rating || '-' %>
                                            <% } %>
                                        </td>
                                    </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    <% } else { %>
                        <p class="ad-no-content">No student outcomes provided.</p>
                    <% } %>

                    <h3 class="ad-section-heading">Course Outcomes (CO)</h3>
                    <% if (locals.cos && locals.cos.length > 0) { %>
                        <table class="ad-data-table">
                            <thead>
                                <tr>
                                    <th style="width:15%; text-align: center;">CO. No</th>
                                    <th style="text-align: left;">Description</th>
                                    <th style="width:25%; text-align: left;">Thinking Skills</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% locals.cos.forEach(function(co) { %>
                                    <tr>
                                        <td style="font-weight:bold; text-align:center;"><%= co.coNumber %></td>
                                        <td><%= co.description %></td>
                                        <td><%= co.thinkingSkills %></td>
                                    </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    <% } else { %>
                        <p class="ad-no-content">No course outcomes provided.</p>
                    <% } %>

                    <h3 class="ad-section-heading">Course Mapping</h3>
                    <% if (locals.mappings && locals.mappings.length > 0) { %>
                        <table class="ad-data-table" style="text-align: center;">
                            <thead>
                                <tr>
                                    <th>CO</th>
                                    <th>a</th>
                                    <th>b</th>
                                    <th>c</th>
                                    <th>d</th>
                                    <th>e</th>
                                    <th>f</th>
                                    <th>g</th>
                                    <th>h</th>
                                    <th>i</th>
                                    <th>j</th>
                                    <th>k</th>
                                    <th>l</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% locals.mappings.forEach(function(m) { %>
                                    <tr>
                                        <td style="font-weight:bold; background:#f9f9f9;">CO<%= m.numberOfCO %></td>
                                        <% for(let i=0; i<12; i++) { %>
                                            <td><%= m.fromAtoL && m.fromAtoL[i] ? m.fromAtoL[i] : '-' %></td>
                                        <% } %>
                                    </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    <% } else { %>
                        <p class="ad-no-content">No course mappings provided.</p>
                    <% } %>

                    <h3 class="ad-section-heading">Concept Map</h3>
                    <% if (locals.syl && locals.syl.conceptMap) { %>
                        <div class="ad-concept-map">
                            <img src="<%= locals.syl.conceptMap %>" alt="Concept Map">
                        </div>
                    <% } else { %>
                        <p class="ad-no-content">No concept map image provided.</p>
                    <% } %>

                    <h3 class="ad-section-heading">Course Schedule</h3>
                    <% if (locals.schedules && locals.schedules.length > 0) { %>
                        <table class="ad-data-table" style="font-size: 0.85rem;">
                            <thead>
                                <tr>
                                    <th style="width: 10%;">Week</th>
                                    <th style="width: 30%;">Topic</th>
                                    <th style="width: 30%;">TLA </th>
                                    <th style="width: 30%;">Assessment Task</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% locals.schedules.forEach(function(s) { %>
                                    <tr>
                                        <td style="font-weight:bold; text-align:center; background:#f9f9f9;">Wk <%= s.week %></td>
                                        <td><%= s.coverageTopic || '-' %></td>
                                        <td>
                                            <div style="margin-bottom:0.25rem;"><strong>Mode:</strong> <%= s.tlaMode || '-' %></div>
                                            <div><strong>Activity:</strong> <%= s.tlaActivities || '-' %></div>
                                        </td>
                                        <td>
                                            <div style="margin-bottom:0.25rem;"><strong>Mode:</strong> <%= s.assessmentTaskMode || '-' %></div>
                                            <div><strong>Task:</strong> <%= s.assessmentTaskTask || '-' %></div>
                                        </td>
                                    </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    <% } else { %>
                        <p class="ad-no-content">No schedule provided.</p>
                    <% } %>

                    <!-- ── Signature Block for PDF Export ── -->
                    <div id="document-signature-section" class="ad-signature-block">
                        <div class="ad-signature-block-content">
                            <p class="ad-signature-label">Approved by:</p>
                            <div id="preview-signature-img-container" class="ad-signature-img-container">
                                <!-- Signature image will be placed here -->
                            </div>
                            <p id="preview-signatory-name" class="ad-signature-name">DEAN</p>
                            <p class="ad-signature-title">Dean</p>
                        </div>
                    </div>

                </div>
            </section>

            <!-- ─── RIGHT: Approval Sidebar ─────────────────────────── -->
            <aside class="ad-sidebar">

                <h3 class="ad-sidebar-title">Dean Endorsement</h3>

                <!-- ── Approval Progress Tracker ── -->
                <div class="ad-tracker">
                    <% const steps=[ { role: 'Faculty' , label: 'Submitted' , status: 'approved' }, { role: 'Technical'
                        , label: 'Reviewed' , status: 'approved' }, { role: 'Program Chair' , label: 'Endorsed' ,
                        status: 'approved' }, { role: 'Dean' , label: 'On-Going' , status: 'ongoing' }, { role: 'HR' ,
                        label: 'Pending' , status: 'pending' } ]; %>

                        <div class="ad-tracker-steps">
                            <% steps.forEach(function(step, idx) { %>
                                <div class="ad-tracker-step">
                                    <div class="ad-step-dot step-<%= step.status %>"></div>
                                    <% if (idx < steps.length - 1) { %>
                                        <div class="ad-step-line line-<%= step.status %>"></div>
                                        <% } %>
                                            <div class="ad-step-labels">
                                                <span class="ad-step-role">
                                                    <%= step.role %>
                                                </span>
                                                <span class="ad-step-sublabel">
                                                    <%= step.label %>
                                                </span>
                                            </div>
                                </div>
                                <% }); %>
                        </div>
                </div>

                <!-- ── Comments ── -->
                <div class="ad-sidebar-section">
                    <label class="ad-sidebar-label">Comments</label>
                    <textarea id="approval-comments" class="ad-comments-box" rows="5"
                        placeholder="Add approval remarks..."><%= locals.existingComment || '' %></textarea>
                </div>

                <!-- ── Status Dropdown ── -->
                <div class="ad-sidebar-section">
                    <label class="ad-sidebar-label">Status</label>
                    <div class="ad-status-select-wrapper">
                        <span class="ad-status-indicator" id="status-indicator"></span>
                        <select id="approval-status" class="ad-status-select">
                            <option value="Approved" <%=locals.currentStatus==='Approved' ? 'selected' : '' %>>Approved</option>
                            <option value="Returned to PC" <%=locals.currentStatus==='Returned to PC' || locals.currentStatus==='Returned' ? 'selected' : '' %>>Return to Program Chair</option>
                            <option value="Pending" <%=locals.currentStatus==='Pending' ? 'selected' : '' %>>Pending</option>
                        </select>
                    </div>
                </div>

                <!-- ── Signature Box ── -->
                <div class="ad-sidebar-section" id="signature-section">
                    <label class="ad-sidebar-label">Signatory Name</label>
                    <input type="text" id="signatory-name-input" class="ad-comments-box" 
                        placeholder="e.g. Dr. Juan dela Cruz" 
                        style="margin-bottom: 15px; padding: 10px 12px; height: 40px; box-sizing: border-box;">

                    <label class="ad-sidebar-label">E-Signature</label>
                    <div class="ad-signature-wrapper">
                        <div class="ad-signature-box" id="signature-box">
                            <span class="ad-signature-placeholder">Click to upload signature</span>
                            <input type="file" id="signature-upload" accept="image/*" hidden>
                        </div>
                        <button type="button" class="ad-signature-remove-btn" id="signature-remove"
                            title="Remove signature" style="display: none;">
                            <span class="material-symbols-outlined">cancel</span>
                        </button>
                    </div>
                </div>

                <!-- ── Action Buttons ── -->
                <div class="ad-sidebar-actions">
                    <button type="button" class="ad-btn-action ad-btn-pdf" id="btn-save-pdf">
                        <span class="material-symbols-outlined">picture_as_pdf</span>
                        Save as PDF
                    </button>
                    <button type="button" class="ad-btn-action ad-btn-draft" id="btn-save-draft">
                        <span class="material-symbols-outlined">save</span>
                        Save as Draft
                    </button>
                    <button type="button" class="ad-btn-action ad-btn-submit" id="btn-submit">
                        Submit Endorsement
                    </button>
                </div>
            </aside>
        </div>
    </main>

    <!-- ═══════════════════════════════════════════════════════════
         Hidden data attributes for JS
    ═══════════════════════════════════════════════════════════ -->
    <script>
        const SYLLABUS_APPROVAL_DATA = {
            syllabusId: '<%= locals.syllabusId || "" %>',
            userRole: 'dean',
            postUrl: '/syllabus/dean/approve/<%= locals.syllabusId || "" %>',
            backUrl: '/syllabus/approve',
            actionLabel: 'Approval',
            workflowStep: 'approval',
            optionApproveValue: 'Approved'
        };
    </script>
    <script src="/Syllabus/js/syllabusApprovalDetail.js"></script>
</body>

</html>