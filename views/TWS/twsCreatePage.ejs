<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>TWS: Teaching Workload Sheet</title>

  <link rel="stylesheet" href="/common/css/variables.css" />
  <link rel="stylesheet" href="/TWS/css/twsStyle.css" />
</head>

<body class="tws-app-body">
  <div class="tws-app-layout">
    <aside class="tws-app-sidebar">
      <%- include("../partials/sideMenuBar", { currentPageCategory: "tws" }) %>
    </aside>

    <main class="tws-app-main">
      <div class="tws-app-center">

        <div class="tws-app-title-pill">
          <h1>TWS: Teaching Workload Sheet</h1>
        </div>

        <div class="tws-app-glass">

          <section class="tws-card tws-card-wide">
            <div class="tws-card-header">
              <div class="tws-card-title">My Teaching Workload Sheets</div>
              <a class="tws-create-pill" href="/tws/create">+ Create New TWS</a>
            </div>

            <div class="tws-table">
              <div class="tws-row tws-head">
                <div>Academic Year</div>
                <div>Term</div>
                <div>Date Created</div>
                <div>Status</div>
                <div class="tws-action-col">Action</div>
              </div>

              <% if (!list || list.length === 0) { %>
                <div class="tws-row tws-empty">
                  <div style="grid-column: 1 / -1;">No TWS yet. Click “Create New TWS”.</div>
                </div>
              <% } %>

              <%
                function formatDatePH(value) {
                  var date = value ? new Date(value) : new Date();
                  if (isNaN(date.getTime())) return "—";
                  return date.toLocaleDateString("en-US", {
                    month: "2-digit",
                    day: "2-digit",
                    year: "numeric",
                    timeZone: "Asia/Manila",
                  });
                }
              %>

              <% (list || []).forEach(tws => { %>
                <div class="tws-row">
                  <div><%= tws.faculty?.acadYear || tws.schoolYear || "—" %></div>
                  <div><%= tws.faculty?.term || tws.term || "—" %></div>

                  <div><%= formatDatePH(tws.createdAt) %></div>

                  <div><%= tws.status || "Draft" %></div>

                  <div class="tws-btns tws-dashboard-btns">
                    <a class="tws-btn-white tws-dashboard-action-btn" href="/tws/created-teaching-workload/<%= tws.id %>?mode=view">View</a>
                    <a class="tws-btn-white tws-dashboard-action-btn" href="/tws/faculty/<%= tws.id %>">Edit</a>

                    <form method="POST" action="/tws/<%= tws.id %>/delete" class="tws-dashboard-delete-form" onsubmit="return confirm('Are you sure you want to delete this TWS? This cannot be undone.');">
                      <button class="tws-btn-white tws-dashboard-action-btn" type="submit">Delete</button>
                    </form>
                  </div>
                </div>
              <% }) %>
            </div>
          </section>

          <section class="tws-card tws-card-guidelines">
            <div class="tws-card-title">TWS Guidelines</div>
            <ul class="tws-guidelines">
              <li>Submit one Teaching Workload Sheet per semester</li>
              <li>Approved TWS documents are automatically archived.</li>
            </ul>
          </section>

          <div class="tws-next-wrap">
            <a class="tws-next" href="/tws/dashboard">Refresh</a>
          </div>

        </div>
      </div>
    </main>
  </div>
</body>
</html>