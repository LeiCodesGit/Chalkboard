<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>TWS - Faculty Information</title>

  <link rel="stylesheet" href="/common/css/variables.css" />
  <link rel="stylesheet" href="/TWS/css/twsStyle.css" />
</head>

<body class="tws-app-body">
  <div class="tws-app-layout">
    <aside class="tws-app-sidebar">
      <%- include("../partials/sideMenuBar", { currentPageCategory: "tws" }) %>
    </aside>

    <main class="tws-app-main">
      <div class="tws-app-center">

        <div class="tws-app-title-pill">
          <h1>TWS - Faculty Information</h1>
        </div>

        <section class="tws-card">

          <div class="tws-card-title" style="margin-bottom: 10px;">Faculty Information</div>

          <% if (typeof validationErrors !== "undefined" && validationErrors && validationErrors.length) { %>
            <div style="margin-bottom:14px; padding:12px 14px; border-radius:12px; background:rgba(255, 99, 132, 0.12); border:1px solid rgba(255,255,255,0.14); color:#fff;">
              <div style="font-weight:800; margin-bottom:6px;">Please fix these first:</div>
              <ul style="margin:0; padding-left:18px;">
                <% validationErrors.forEach(function(err) { %>
                  <li><%= err %></li>
                <% }) %>
              </ul>
            </div>
          <% } %>

          <form method="POST" action="/tws/faculty/<%= tws.id %>">

            <div style="display:grid; grid-template-columns: 160px 1fr; gap: 12px; align-items:center; font-size:12px;">

              <div style="font-weight:800;">Faculty Name:</div>
              <input
                type="text"
                name="name"
                value="<%= tws.faculty?.name || '' %>"
                style="height: 16px; border-radius: 999px; border: none; background: rgba(255,255,255,0.25); color:#fff; padding: 12px 14px; outline:none;"
              />

              <div style="font-weight:800;">Employee ID:</div>
              <input
                type="text"
                name="empId"
                value="<%= tws.faculty?.empId || '' %>"
                style="height: 16px; border-radius: 999px; border: none; background: rgba(255,255,255,0.25); color:#fff; padding: 12px 14px; outline:none;"
              />

              <div style="font-weight:800;">Faculty Email:</div>
              <input
                type="email"
                name="email"
                value="<%= tws.faculty?.email || '' %>"
                placeholder="faculty@school.edu"
                style="height: 16px; border-radius: 999px; border: none; background: rgba(255,255,255,0.25); color:#fff; padding: 12px 14px; outline:none;"
              />

              <div style="font-weight:800;">Department:</div>
              <input
                type="text"
                name="dept"
                value="<%= tws.faculty?.dept || '' %>"
                style="height: 16px; border-radius: 999px; border: none; background: rgba(255,255,255,0.25); color:#fff; padding: 12px 14px; outline:none;"
              />

              <div style="font-weight:800;">Academic Year:</div>
              <input
                type="text"
                name="acadYear"
                placeholder="2025 - 2026"
                value="<%= tws.faculty?.acadYear || '' %>"
                style="height: 16px; border-radius: 999px; border: none; background: rgba(255,255,255,0.25); color:#fff; padding: 12px 14px; outline:none;"
              />

              <div style="font-weight:800;">Term:</div>
              <input
                type="text"
                name="term"
                placeholder="1st / 2nd / 3rd"
                value="<%= tws.faculty?.term || '' %>"
                style="height: 16px; border-radius: 999px; border: none; background: rgba(255,255,255,0.25); color:#fff; padding: 12px 14px; outline:none;"
              />

              <div style="font-weight:800;">Employee Status:</div>
              <input
                type="text"
                name="empStatus"
                value="<%= tws.faculty?.empStatus || '' %>"
                style="height: 16px; border-radius: 999px; border: none; background: rgba(255,255,255,0.25); color:#fff; padding: 12px 14px; outline:none;"
              />
            </div>

            <div style="font-size:11px; opacity:.88; margin-top:12px; line-height:1.5;">
              Tip: You can assign the TWS using <b>Employee ID</b>, <b>Email</b>, or both.
              Using both is better for more accurate professor matching.
            </div>

            <div class="tws-next-wrap" style="margin-top: 16px;">
              <a class="tws-btn-white" href="/tws/dashboard">Back</a>

              <button class="tws-btn-white" type="submit" name="action" value="save" style="cursor:pointer;">
                Save Draft
              </button>

              <button class="tws-next" type="submit" name="action" value="next" style="cursor:pointer;">
                Next
              </button>
            </div>

          </form>
        </section>

      </div>
    </main>
  </div>
</body>
</html>