<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8" />
  <title>Teaching Workload Sheet PDF</title>
  <style>
    body {
      font-family: Arial, Helvetica, sans-serif;
      color: #111;
      margin: 0;
      padding: 0;
      font-size: 12px;
      line-height: 1.4;
    }

    .page {
      width: 100%;
    }

    .header {
      text-align: center;
      margin-bottom: 18px;
    }

    .header h1 {
      margin: 0;
      font-size: 20px;
      letter-spacing: 0.4px;
    }

    .header .sub {
      margin-top: 4px;
      font-size: 11px;
      color: #444;
    }

    .meta-grid {
      display: grid;
      grid-template-columns: 140px 1fr 140px 1fr;
      gap: 8px 10px;
      margin-bottom: 18px;
    }

    .label {
      font-weight: bold;
    }

    .box {
      border: 1px solid #000;
      padding: 6px 8px;
      min-height: 18px;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 18px;
    }

    th, td {
      border: 1px solid #000;
      padding: 7px 8px;
      vertical-align: top;
      font-size: 11px;
    }

    th {
      background: #f0f0f0;
      text-align: left;
    }

    .totals {
      width: 280px;
      margin-left: auto;
      margin-bottom: 22px;
    }

    .totals td:first-child {
      font-weight: bold;
      width: 60%;
    }

    .section-title {
      font-size: 13px;
      font-weight: bold;
      margin: 18px 0 8px;
    }

    .signature-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
      margin-top: 28px;
    }

    .sig-box {
      text-align: center;
    }

    .sig-image-wrap {
      height: 70px;
      display: flex;
      align-items: end;
      justify-content: center;
      margin-bottom: 6px;
    }

    .sig-image {
      max-width: 180px;
      max-height: 60px;
      object-fit: contain;
    }

    .sig-line {
      border-top: 1px solid #000;
      margin-top: 6px;
      padding-top: 4px;
      font-weight: bold;
    }

    .sig-role {
      font-size: 11px;
      margin-top: 2px;
      color: #444;
    }

    .footer {
      margin-top: 22px;
      font-size: 10px;
      color: #555;
      text-align: right;
    }

    .muted {
      color: #555;
      font-size: 10px;
    }
  </style>
</head>
<body>
  <div class="page">

    <div class="header">
      <h1>Teaching Workload Sheet</h1>
      <div class="sub">Final Approved Record</div>
    </div>

    <div class="meta-grid">
      <div class="label">Faculty Name</div>
      <div class="box"><%= tws?.faculty?.name || "—" %></div>

      <div class="label">Employee ID</div>
      <div class="box"><%= tws?.faculty?.empId || "—" %></div>

      <div class="label">Faculty Email</div>
      <div class="box"><%= tws?.faculty?.email || "—" %></div>

      <div class="label">Department</div>
      <div class="box"><%= tws?.faculty?.dept || "—" %></div>

      <div class="label">Academic Year</div>
      <div class="box"><%= tws?.faculty?.acadYear || tws?.schoolYear || "—" %></div>

      <div class="label">Term</div>
      <div class="box"><%= tws?.faculty?.term || tws?.term || "—" %></div>

      <div class="label">Employee Status</div>
      <div class="box"><%= tws?.faculty?.empStatus || "—" %></div>

      <div class="label">Status</div>
      <div class="box"><%= tws?.status || "—" %></div>
    </div>

    <div class="section-title">Created Teaching Workload</div>

    <table>
      <thead>
        <tr>
          <th style="width: 14%;">Course Code</th>
          <th style="width: 34%;">Course Title</th>
          <th style="width: 10%;">Units</th>
          <th style="width: 22%;">Schedule</th>
          <th style="width: 20%;">Section / Room</th>
        </tr>
      </thead>
      <tbody>
        <% if (!tws?.createdWorkload || !tws.createdWorkload.length) { %>
          <tr>
            <td colspan="5">No created workload records found.</td>
          </tr>
        <% } %>

        <% (tws?.createdWorkload || []).forEach(function(item) { %>
          <tr>
            <td><%= item.code || "—" %></td>
            <td><%= item.title || "—" %></td>
            <td><%= Number(item.units || 0).toFixed(2) %></td>
            <td><%= item.timeSlot || "—" %></td>
            <td><%= item.sectionRoom || "—" %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>

    <div class="section-title">Teaching Load Details</div>

    <table>
      <thead>
        <tr>
          <th style="width: 18%;">Course Code</th>
          <th style="width: 34%;">Course Title</th>
          <th style="width: 12%;">Units</th>
          <th style="width: 12%;">LEC</th>
          <th style="width: 12%;">LAB</th>
          <th style="width: 12%;">Sections</th>
        </tr>
      </thead>
      <tbody>
        <% if (!tws?.loads || !tws.loads.length) { %>
          <tr>
            <td colspan="6">No teaching load details found.</td>
          </tr>
        <% } %>

        <% (tws?.loads || []).forEach(function(load) { %>
          <tr>
            <td><%= load.courseCode || "—" %></td>
            <td><%= load.courseTitle || "—" %></td>
            <td><%= Number(load.units || 0).toFixed(2) %></td>
            <td><%= Number(load.lec || 0).toFixed(2) %></td>
            <td><%= Number(load.lab || 0).toFixed(2) %></td>
            <td><%= Number(load.sections || 0) %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>

    <table class="totals">
      <tbody>
        <tr>
          <td>Total Units</td>
          <td><%= Number(tws?.totals?.totalUnits || 0).toFixed(2) %></td>
        </tr>
        <tr>
          <td>Total Hours</td>
          <td><%= Number(tws?.totals?.totalHours || 0).toFixed(2) %></td>
        </tr>
        <tr>
          <td>Equivalent Load</td>
          <td><%= Number(tws?.totals?.equivLoad || 0).toFixed(2) %></td>
        </tr>
      </tbody>
    </table>

    <div class="signature-grid">
      <div class="sig-box">
        <div class="sig-image-wrap">
          <% if (tws?.facultySignatureImage) { %>
            <img class="sig-image" src="<%= tws.facultySignatureImage %>" alt="Faculty Signature" />
          <% } %>
        </div>
        <div class="sig-line"><%= tws?.facultySignerName || tws?.faculty?.name || "Faculty" %></div>
        <div class="sig-role">FACULTY</div>
        <% if (tws?.facultySignedAt) { %>
          <div class="muted">
            Signed on
            <%= new Date(tws.facultySignedAt).toLocaleString("en-US", { timeZone: "Asia/Manila" }) %>
            (PHT)
          </div>
        <% } %>
      </div>

      <div class="sig-box">
        <div class="sig-image-wrap"></div>
        <div class="sig-line"><%= tws?.programChairName || "Program Chair" %></div>
        <div class="sig-role">PROGRAM CHAIR</div>
      </div>

      <div class="sig-box">
        <div class="sig-image-wrap"></div>
        <div class="sig-line"><%= tws?.deanName || "Dean" %></div>
        <div class="sig-role">DEAN</div>
      </div>
    </div>

    <div class="footer">
      Generated on
      <%= new Date(generatedAt).toLocaleString("en-US", { timeZone: "Asia/Manila" }) %>
      (PHT)
    </div>
  </div>
</body>
</html>