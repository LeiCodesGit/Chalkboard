<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Chalkboard | ATA Pending Approvals</title>
    <link rel="icon" type="image/x-icon" href="/common/img/chalkboardLogo.ico">
    <link rel="stylesheet" href="/ATA/css/pending-approvals.css">
    
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" />
    <script src="https://cdn.jsdelivr.net/npm/signature_pad@4.1.5/dist/signature_pad.umd.min.js"></script>
    
</head>
<body data-role="<%= typeof role !== 'undefined' ? role : 'Admin' %>"
      data-employment="<%= (typeof user !== 'undefined' && user.employmentType) ? user.employmentType : 'Full-Time' %>"
      data-practicum="<%= (typeof user !== 'undefined' && user.isPracticumCoordinator) ? 'true' : 'false' %>"
      data-user-sig="<%= typeof user !== 'undefined' && user.signatureImage ? user.signatureImage : '' %>">
      
    <% 
        if (typeof role !== 'undefined') {
            if (['Admin', 'VPAA', 'HR', 'HRMO'].includes(role)) { %>
                <%- include('../MainPages/admin/partials/adminSideMenuBar') %>
            <% } else if (role === 'Dean') { %>
                <%- include('../MainPages/dean/partials/deanMenuBar') %>
            <% } else if (role === 'Program-Chair') { %>
                <%- include('../MainPages/progChair/partials/progChairMenuBar') %>
            <% } else { %>
                <%- include('../partials/sideMenuBar') %>
            <% } 
        } else { %>
            <%- include('../partials/sideMenuBar') %>
        <% }
    %>
    
    <main class="main-content" style="margin-left: 260px; width: calc(100vw - 260px);">

        <div class="bb-page-header">
            <div class="user-profile-row">
                <div class="user-avatar">
                    <% if (typeof isHistory !== 'undefined' && isHistory) { %>
                        <i class="fas fa-history" style="color: #4a9eff;"></i>
                    <% } else { %>
                        <i class="fas fa-inbox" style="color: #ffc107;"></i>
                    <% } %>
                </div>
                <div class="user-name">
                    <% if (typeof isHistory !== 'undefined' && isHistory) { %>
                        Processed & Approved Forms
                    <% } else { %>
                        Forms to Approve
                    <% } %>
                </div>
            </div>

            <div class="search-wrapper">
                <i class="fas fa-search"></i>
                <input type="text" id="facultySearchInput" class="search-input" placeholder="Search by Faculty Name...">
            </div>

            <a href="<%= (typeof role !== 'undefined' && ['Admin', 'VPAA', 'HR', 'HRMO'].includes(role)) ? '/admin/ata' : '/ata/dashboard/window' %>" class="btn-outline">
                <i class="fas fa-arrow-left"></i> Back to Dashboard
            </a>
        </div>

        <div class="bb-scroll-area">
            
            <div class="bb-accent-line"></div>

            <div class="bb-tabs-wrapper">
                <div>
                    <div class="bb-tab">
                        <% if (typeof isHistory !== 'undefined' && isHistory) { %>
                            Approval History
                        <% } else { %>
                            Pending Inbox
                        <% } %>
                        <span style="color: #888; font-weight: normal; font-size: 13px; margin-left: 10px;">
                            (<%= role %> - <%= college %>)
                        </span>
                    </div>
                </div>

                <% if (typeof isHistory === 'undefined' || !isHistory) { %>
                    <div class="signature-actions-bar">
                        <span style="font-size: 13px; font-weight: 600; color: #666; margin-right: 5px;">
                            <i class="fas fa-pen-nib"></i> E-Signature:
                        </span>

                        <button id="openSignatureModal" class="btn-action" style="background: <%= typeof user !== 'undefined' && user.signatureImage ? '#17a2b8' : '#28a745' %>; color: white;">
                            <i class="fas fa-signature"></i> <%= typeof user !== 'undefined' && user.signatureImage ? 'Change' : 'Setup' %>
                        </button>

                        <% if (typeof user !== 'undefined' && user.signatureImage) { %>
                            <button type="button" id="mainPreviewSigBtn" class="btn-action" style="background: #6c757d; color: white;">
                                <i class="fas fa-file-pdf"></i> Preview
                            </button>
                            
                            <button type="button" id="mainDeleteSigBtn" class="btn-action" style="background: #dc3545; color: white;">
                                <i class="fas fa-trash"></i> Delete
                            </button>
                        <% } %>
                    </div>
                <% } %>
            </div>

            <div class="bb-table-container">
                <table class="bb-table" id="approvalsTable">
                    <thead>
                        <tr>
                            <th style="width: 60px;"></th>
                            <th style="width: 25%;">Faculty Name <i class="fas fa-sort"></i></th>
                            <th style="width: 25%;">Approval Track <i class="fas fa-sort"></i></th>
                            <th style="width: 15%;">Term <i class="fas fa-sort"></i></th>
                            <th style="width: 15%;">Status <i class="fas fa-sort"></i></th>
                            <th style="width: 10%; text-align: center;">Action <i class="fas fa-sort"></i></th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (forms.length === 0) { %>
                            <tr class="no-data-row">
                                <td colspan="6" style="padding: 60px; text-align: center; color: #888; font-size: 16px;">
                                    <% if (typeof isHistory !== 'undefined' && isHistory) { %>
                                        <i class="fas fa-folder-open" style="font-size: 40px; margin-bottom: 15px; display: block; color: #ccc;"></i>
                                        Your approved history is currently empty.
                                    <% } else { %>
                                        <i class="fas fa-check-circle" style="font-size: 40px; margin-bottom: 15px; display: block; color: #28a745;"></i>
                                        You're all caught up! No pending forms require your attention.
                                    <% } %>
                                </td>
                            </tr>
                        <% } else { %>
                            <% forms.forEach(form => { %>
                                <tr class="data-row">
                                    <td class="row-icon-cell">
                                        <div class="row-icon-wrapper">
                                            <% if (form.status !== 'FINALIZED') { %>
                                                <span class="row-dot"></span>
                                            <% } else { %>
                                                <span class="row-dot" style="background-color: transparent;"></span>
                                            <% } %>
                                            <i class="fas fa-file-signature row-icon" style="color: #444;"></i>
                                        </div>
                                    </td>

                                    <td class="searchable-name">
                                        <div style="font-weight: 700; font-size: 15px;"><%= form.facultyName %></div>
                                        <div style="font-size: 12px; color: #777;"><%= form.college %></div>
                                    </td>

                                    <td>
                                        <% if (form.approvalHistory && form.approvalHistory.length > 0) { %>
                                            <% const revHistory = [...form.approvalHistory].reverse(); %>
                                            <ul class="track-list">
                                                <% revHistory.forEach((log, index) => { %>
                                                    <li class="track-item <%= index > 0 ? 'hidden-track' : '' %>" style="<%= index > 0 ? 'display: none;' : '' %>">
                                                        <% if (log.approvalStatus === 'RETURNED' || log.approvalStatus === 'REJECTED') { %>
                                                            <i class="fas fa-times-circle" style="color: #dc3545; margin-top: 3px;"></i>
                                                        <% } else { %>
                                                            <i class="fas fa-check-circle" style="color: #28a745; margin-top: 3px;"></i>
                                                        <% } %>
                                                        <div>
                                                            <strong style="color: #222;"><%= log.approverName || log.approverRole %></strong> 
                                                            (<%= log.approvalStatus %>) <br>
                                                            <span style="font-size: 11px; color: #888;"><%= new Date(log.date).toLocaleDateString() %></span>
                                                            
                                                            <% if (log.approvalStatus === 'RETURNED' && log.remarks) { %>
                                                                <div class="track-reason">
                                                                    <strong>Reason:</strong> <%= log.remarks %>
                                                                </div>
                                                            <% } %>
                                                        </div>
                                                    </li>
                                                <% }) %>
                                            </ul>
                                            
                                            <% if (revHistory.length > 1) { %>
                                                <button type="button" onclick="toggleHistory(this)" style="background: transparent; border: none; color: #a0a0a0; font-size: 11px; font-weight: bold; cursor: pointer; padding: 5px 0 0 0; display: inline-flex; align-items: center; gap: 5px;">
                                                    <i class="fas fa-chevron-down"></i> <span class="toggle-txt">View <%= revHistory.length - 1 %> older actions</span>
                                                </button>
                                            <% } %>

                                        <% } else { %>
                                            <span style="color: #888; font-style: italic;">No actions yet.</span>
                                        <% } %>
                                    </td>

                                    <td>
                                        <div style="font-weight: 600;"><%= form.term %></div>
                                        <div style="font-size: 12px; color: #777;"><%= form.academicYear %></div>
                                    </td>

                                    <td>
                                        <% 
                                            let displayStatus = form.status.replace('PENDING_', 'Awaiting ');
                                            if (displayStatus === 'Awaiting PRACTICUM') displayStatus = 'Awaiting Practicum';
                                            if (displayStatus === 'Awaiting CHAIR') displayStatus = 'Awaiting Chair';
                                            if (displayStatus === 'Awaiting DEAN') displayStatus = 'Awaiting Dean';
                                        %>
                                        <% if (form.status === 'FINALIZED') { %>
                                            <span class="badge-green"><i class="fas fa-check-double"></i> Finalized</span>
                                        <% } else { %>
                                            <span class="badge-yellow"><i class="fas fa-clock"></i> <%= displayStatus %></span>
                                        <% } %>
                                    </td>

                                    <td style="text-align: center;">
                                        <div style="display: flex; flex-direction: column; align-items: center;">
                                            <% if (typeof isHistory !== 'undefined' && isHistory) { %>
                                                <a href="/ata/view-submission/<%= form._id %>" class="btn-dark">
                                                    View Form
                                                </a>
                                            <% } else { %>
                                                <a href="/ata/view/<%= form._id %>" class="btn-dark">
                                                    Review
                                                </a>
                                            <% } %>
                                        </div>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } %>
                    </tbody>
                </table>
            </div>

        </div> </main>

    <div class="modal-overlay" id="sigModalOverlay">
        <div class="signature-modal">
            <h2 style="margin: 0; font-size: 1.5rem; border-bottom: 2px solid #b30000; padding-bottom: 10px;">
                <i class="fas fa-lock"></i> VIP Signature Vault
            </h2>
            <p style="font-size: 0.9rem; color: #ccc;">
                Draw your signature below. This will be securely saved to your profile and automatically stamped on ATA forms when you click "Approve".
            </p>
            <% if (typeof user !== 'undefined' && user.signatureImage) { %>
                <div style="font-size: 0.8rem; color: #aaa;">Current Saved Signature:</div>
                <div class="signature-preview-box">
                    <img src="<%= user.signatureImage %>" style="max-height: 80px;">
                </div>
            <% } %>
            <div style="font-size: 0.8rem; color: #aaa; margin-top: 10px;">Draw New Signature:</div>
            <div style="background: #e9ecef; border-radius: 5px; padding: 5px;">
                <canvas id="vipSignatureCanvas" width="440" height="150" style="cursor: crosshair;"></canvas>
            </div>
            <div style="display: flex; justify-content: space-between; margin-top: 15px;">
                <button type="button" id="clearVipSigBtn" class="btn-action" style="background: #444; color: white; padding: 6px 12px; font-size: 12px;">
                    <i class="fas fa-eraser"></i> Clear Canvas
                </button>
                <button type="button" id="deleteVipSigBtn" class="btn-action" 
                        style="background: <%= typeof user !== 'undefined' && user.signatureImage ? '#dc3545' : '#6c757d' %>; color: white; padding: 6px 12px; font-size: 12px; cursor: <%= typeof user !== 'undefined' && user.signatureImage ? 'pointer' : 'not-allowed' %>;"
                        <%= typeof user !== 'undefined' && user.signatureImage ? '' : 'disabled' %>>
                        <i class="fas fa-trash"></i> Delete
                </button>
                <div style="display: flex; gap: 8px;">
                    <button type="button" id="closeVipSigBtn" class="btn-action" style="background: #dc3545; color: white; padding: 6px 12px; font-size: 12px;">Cancel</button>
                    <button type="button" id="previewVipSigBtn" class="btn-action" style="background: #17a2b8; color: white; padding: 6px 12px; font-size: 12px;">
                        <i class="fas fa-file-pdf"></i> Preview
                    </button>
                    <button type="button" id="saveVipSigBtn" class="btn-action" style="background: #28a745; color: white; padding: 6px 12px; font-size: 12px;">
                        <i class="fas fa-save"></i> Save
                    </button>
                </div>
            </div>
        </div>
    </div>
    
    <script src="/ATA/js/ata_client.js"></script>
    <script src="/ATA/js/pending-approvals.js"></script>
</body>
</html>