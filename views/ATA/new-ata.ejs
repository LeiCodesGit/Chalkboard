<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Chalkboard | New ATA Form</title>
    <link rel="icon" type="image/x-icon" href="/common/img/chalkboardLogo.ico">
    
    <link rel="stylesheet" href="/common/css/variables.css">
    <link rel="stylesheet" href="/ATA/css/new-ata.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
</head>
<body data-role="<%= typeof role !== 'undefined' ? role : '' %>" 
      data-employment="<%= typeof employmentType !== 'undefined' ? employmentType : '' %>"
      data-practicum="<%= typeof isPracticumCoordinator !== 'undefined' ? isPracticumCoordinator : 'false' %>">

    <% 
        if (typeof role !== 'undefined') {
            if (['Admin', 'VPAA', 'HR', 'HRMO'].includes(role)) { %>
                <%- include('../MainPages/admin/partials/adminSideMenuBar') %>
            <% } else if (role === 'Dean') { %>
                <%- include('../MainPages/dean/partials/deanMenuBar') %>
            <% } else if (role === 'Program-Chair') { %>
                <%- include('../MainPages/progChair/partials/progChairMenuBar') %>
            <% } else { %>
                <%- include('../partials/sideMenuBar') %>
            <% } 
        } else { %>
            <%- include('../partials/sideMenuBar') %>
        <% }
    %>

    <main id="multiStepSection">

        <div class="bb-top-bar">
            <h1>ATA Form</h1>
        </div>

        <div class="bb-nav-container">
            <div id="formTitle">
                <h1>Personal Details</h1>
            </div>

            <div class="bb-nav-row">
                <button id="backBtn" type="button">Back</button>

                <div class="progress-steps">
                    <span class="progress-dot active" id="step1Dot" data-label="Personal Details">1</span>
                    <span class="progress-dot" id="step2Dot" data-label="Teaching Load">2</span>
                    <span class="progress-dot" id="step3Dot" data-label="Admin & Practicum">3</span>
                    <span class="progress-dot" id="step4Dot" data-label="Outside Employment">4</span>
                    <span class="progress-dot" id="step5Dot" data-label="Remedial Modules">5</span>
                    <span class="progress-dot" id="step6Dot" data-label="Review">6</span>
                    
                    <% 
                        let adminRoleForDot = (typeof role !== 'undefined' && role) ? role : ((typeof user !== 'undefined' && user && user.role) ? user.role : '');
                        if (['Program-Chair', 'Dean', 'Admin', 'VPAA', 'HR', 'HRMO'].includes(adminRoleForDot)) { 
                    %>
                        <span class="progress-dot" id="step7Dot" data-label="Approval">7</span>
                    <% } %>
                </div>

                <button id="nextBtn" type="button">Next</button>
            </div>
        </div>

        <div class="form-cards-container">
            
            <div class="form-card-scrollable" id="form1">
                <div class="ata-form">
                    <% if (typeof form !== 'undefined' && form._id) { %>
                        <input type="hidden" id="existingDraftId" value="<%= form._id %>">
                    <% } %>
                    
                    <div class="form-row">
                        <div class="form-label">NAME</div>
                        <div class="form-field">
                            <input type="text" class="form-input" id="facultyName" value="<%= user.name %>" readonly style="background-color: #e9ecef !important; color: #666 !important; cursor: not-allowed; border-color: #ccc !important;">
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-label">POSITION</div>
                        <div class="form-field">
                            <select class="form-input" id="position">
                                <option value="" disabled <%= !role ? 'selected' : '' %>>Select your position</option>
                                <option value="Professor" <%= role === 'Professor' ? 'selected' : '' %>>Professor</option>
                                <option value="Assistant Professor" <%= role === 'Assistant Professor' ? 'selected' : '' %>>Assistant Professor</option>
                                <option value="Associate Professor" <%= role === 'Associate Professor' ? 'selected' : '' %>>Associate Professor</option>
                                <option value="Program-Chair" <%= role === 'Program-Chair' ? 'selected' : '' %>>Program Chair</option>
                                <option value="Dean" <%= role === 'Dean' ? 'selected' : '' %>>Dean</option>
                                <option value="Practicum-Coordinator" <%= role === 'Practicum-Coordinator' ? 'selected' : '' %>>Practicum Coordinator</option>
                            </select>
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-label">COLLEGE / PROGRAM</div>
                        <div class="form-field">
                            <select class="form-input" id="college">
                                <option value="" disabled <%= !user.program && role !== 'Dean' ? 'selected' : '' %>>Select your College or Program</option>
                                <option value="CEA" <%= role === 'Dean' || user.program === 'CEA' ? 'selected' : '' %>>College of Engineering & Architecture (CEA)</option>
                                <optgroup label="College of Engineering & Architecture (CEA)">
                                    <option value="CpE" <%= user.program === 'CpE' ? 'selected' : '' %>>Computer Engineering (CpE)</option>
                                    <option value="CE" <%= user.program === 'CE' ? 'selected' : '' %>>Civil Engineering (CE)</option>
                                    <option value="EE" <%= user.program === 'EE' ? 'selected' : '' %>>Electrical Engineering (EE)</option>
                                    <option value="ECE" <%= user.program === 'ECE' ? 'selected' : '' %>>Electronics Engineering (ECE)</option>
                                    <option value="IE" <%= user.program === 'IE' ? 'selected' : '' %>>Industrial Engineering (IE)</option> 
                                    <option value="ME" <%= user.program === 'ME' ? 'selected' : '' %>>Mechanical Engineering (ME)</option>
                                    <option value="AR" <%= user.program === 'AR' ? 'selected' : '' %>>Architecture (AR)</option>
                                </optgroup>
                                <optgroup label="Other Colleges">
                                    <option value="CCIS" disabled>College of Computing and Information Sciences (CCIS)</option>
                                    <option value="CAS" disabled>College of Arts and Sciences (CAS)</option>
                                    <option value="ETYCB" disabled>E.T. Yuchengco College of Business (ETYCB)</option>
                                    <option value="CHS" disabled>College of Health Sciences (CHS)</option>
                                </optgroup>
                            </select>
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-label">EMPLOYMENT STATUS</div>
                        <div class="form-field">
                            <select class="form-input" id="employmentStatus">
                                <option value="" disabled selected>Select Status...</option>
                                <option value="Regular">Regular</option>
                                <option value="Probationary">Probationary</option>
                                <option value="Fixed-Term">Fixed-Term</option>
                                <option value="Contractual">Contractual</option>
                                <option value="Guest Lecturer">Guest Lecturer</option>
                            </select>
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-label">EMPLOYMENT TYPE</div>
                        <div class="form-field radio-group">
                            <label class="radio-label"><input type="radio" name="employment" value="Full-Time" id="radioFullTime"> FULL TIME</label>
                            <label class="radio-label"><input type="radio" name="employment" value="Part-Time" id="radioPartTime"> PART TIME</label>
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-label">ADDRESS</div>
                        <div class="form-field">
                            <input type="text" class="form-input" placeholder="Your current address" id="address">
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-label">ACADEMIC TERM</div>
                        <div class="form-field">
                            <select class="form-input" id="term" required>
                                <option value="" disabled selected>Select Term...</option>
                                <option value="1ST">1st Term</option>
                                <option value="2ND">2nd Term</option>
                                <option value="3RD">3rd Term</option>
                                <option value="MIDYEAR">Midyear</option>
                            </select>
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-label">ACADEMIC YEAR</div>
                        <div class="form-field">
                            <input type="text" class="form-input" id="academicYear" placeholder="e.g. 2025" required maxlength="9">
                        </div>
                    </div>

                    <div id="sectionA_Container">
                        <div class="form-row">
                            <div class="form-label">ADMIN UNITS<br><span style="font-size:9px; font-weight:normal; color:#aaa;">(IF APPLICABLE)</span></div>
                            <div class="form-field">
                                <input type="number" class="form-input units-input" placeholder="0" id="teachingUnits1" min="0" oninput="this.value = Math.abs(this.value)" style="max-width: 150px !important;">
                            </div>
                        </div>
                    </div>

                </div>
            </div>

            <div class="form-card-scrollable" id="form2" style="display: none;">
                <div class="ata-form">
                    
                    <div class="form-row">
                        <div class="form-label">ASSIGNED COLLEGE</div>
                        <div class="form-field" style="align-items: stretch; padding-top: 0;">
                            
                            <div class="table-header">
                                <div class="table-col">Course Code</div>
                                <div class="table-col">Section</div>
                                <div class="table-col" style="flex:0.5;">Units</div>
                                <div class="table-col">Effective Date</div>
                                <div class="table-col" style="flex:0.5;">Actions</div>
                            </div>

                            <div class="course-row">
                                <div class="table-col"><input type="text" class="table-input" placeholder="Code"></div>
                                <div class="table-col"><input type="text" class="table-input" placeholder="Sec"></div>
                                <div class="table-col" style="flex:0.5;">
                                    <select class="table-input" required>
                                        <option value="" disabled selected>0</option>
                                        <option value="1">1</option><option value="2">2</option><option value="3">3</option>
                                        <option value="4">4</option><option value="5">5</option><option value="6">6</option>
                                    </select>
                                </div>
                                <div class="table-col"><input type="text" class="table-input date-input" placeholder="DD/MM/YYYY"></div>
                                <div class="table-col action-col" style="flex:0.5;"><button type="button" class="action-btn remove-btn"><i class="fas fa-trash"></i></button></div>
                            </div>
                            
                            <div class="course-row">
                                <div class="table-col"><input type="text" class="table-input" placeholder="Code"></div>
                                <div class="table-col"><input type="text" class="table-input" placeholder="Sec"></div>
                                <div class="table-col" style="flex:0.5;">
                                    <select class="table-input" required>
                                        <option value="" disabled selected>0</option>
                                        <option value="1">1</option><option value="2">2</option><option value="3">3</option>
                                        <option value="4">4</option><option value="5">5</option><option value="6">6</option>
                                    </select>
                                </div>
                                <div class="table-col"><input type="text" class="table-input date-input" placeholder="DD/MM/YYYY"></div>
                                <div class="table-col action-col" style="flex:0.5;"><button type="button" class="action-btn remove-btn"><i class="fas fa-trash"></i></button></div>
                            </div>

                            <div class="add-course-btn" style="padding: 15px 0;">
                                <button type="button" class="secondary-btn">+ Add Course</button>
                            </div>

                            <div class="total-units-row">
                                <span>Total Units (B):</span><span class="total-value">0</span>
                            </div>

                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-label">OTHER COLLEGES</div>
                        <div class="form-field" style="align-items: stretch; padding-top: 0;">
                            
                            <div class="table-header">
                                <div class="table-col">Course Code</div>
                                <div class="table-col">Section</div>
                                <div class="table-col" style="flex:0.5;">Units</div>
                                <div class="table-col">Effective Date</div>
                                <div class="table-col" style="flex:0.5;">Status</div>
                            </div>

                            <div class="course-row">
                                <div class="table-col"><input type="text" class="table-input" placeholder="Code"></div>
                                <div class="table-col"><input type="text" class="table-input" placeholder="Sec"></div>
                                <div class="table-col" style="flex:0.5;">
                                    <select class="table-input" required>
                                        <option value="" disabled selected>0</option>
                                        <option value="1">1</option><option value="2">2</option><option value="3">3</option>
                                        <option value="4">4</option><option value="5">5</option><option value="6">6</option>
                                    </select>
                                </div>
                                <div class="table-col"><input type="text" class="table-input date-input" placeholder="DD/MM/YYYY"></div>
                                <div class="table-col" style="flex:0.5;"><span style="color: #d39e00; font-size: 11px;"><i class="fas fa-clock"></i> Pending</span></div>
                            </div>

                            <div class="add-course-btn" style="padding: 15px 0;">
                                <button type="button" class="secondary-btn">+ Add Course</button>
                            </div>

                            <div class="total-units-row">
                                <span>Total Units (C):</span><span class="total-value">0</span>
                            </div>

                        </div>
                    </div>

                </div>
            </div>

            <div class="form-card-scrollable" id="form3" style="display: none;">
                <div class="ata-form">
                    
                    <div id="sectionD_Container" class="form-row">
                    <div class="form-label">ADMIN WORK</div>
                    <div class="form-field" style="align-items: stretch; padding-top: 0;">
                            
                            <div class="admin-header">
                                <div class="admin-col" style="flex:2;">Work Description</div>
                                <div class="admin-col" style="flex:0.5;">Units</div>
                                <div class="admin-col">Effective Date</div>
                                <div class="admin-col" style="flex:0.5;">Actions</div>
                            </div>

                            <div class="admin-row">
                                <div class="admin-col" style="flex:2;"><input type="text" class="table-input" placeholder="Description"></div>
                                <div class="admin-col" style="flex:0.5;">
                                    <select class="table-input" required>
                                        <option value="" disabled selected>0</option>
                                        <option value="1">1</option><option value="2">2</option><option value="3">3</option>
                                    </select>
                                </div>
                                <div class="admin-col"><input type="text" class="table-input date-input" placeholder="DD/MM/YYYY"></div>
                                <div class="admin-col" style="flex:0.5;"><button type="button" class="action-btn remove-btn"><i class="fas fa-trash"></i></button></div>
                            </div>

                            <div class="add-course-btn" style="padding: 15px 0;">
                                <button type="button" class="secondary-btn">+ Add Work</button>
                            </div>

                            <div class="total-units-row">
                                <span>Total Units (D):</span><span class="total-value">0</span>
                            </div>
                        </div>
                    </div>
                    
                    <div class="form-row">
                        <div class="form-label">PRACTICUM</div>
                        <div class="form-field" style="align-items: stretch; padding-top: 0;">

                            <div class="practicum-header">
                                <div class="practicum-col">Course Code</div>
                                <div class="practicum-col" style="flex:0.5;">Students</div>
                                <div class="practicum-col" style="flex:1.5;">Coordinator</div>
                                <div class="practicum-col" style="flex:0.5;">Actions</div>
                            </div>

                            <div class="practicum-row">
                                <div class="practicum-col"><input type="text" class="table-input" placeholder="Code"></div>
                                <div class="practicum-col" style="flex:0.5;"><input type="text" class="table-input" placeholder="#"></div>
                                <div class="practicum-col" style="flex:1.5;">
                                    <select class="table-input" required>
                                        <option value="" disabled selected>Select Coordinator</option>
                                        <% if (typeof coordinators !== 'undefined' && coordinators.length > 0) { %>
                                            <% coordinators.forEach(function(name) { %>
                                                <option value="<%= name %>"><%= name %></option>
                                            <% }); %>
                                        <% } %>
                                    </select>
                                </div>
                                <div class="practicum-col" style="flex:0.5;"><button type="button" class="action-btn remove-btn"><i class="fas fa-trash"></i></button></div>
                            </div>

                            <div class="add-course-btn" style="padding: 15px 0;">
                                <button type="button" class="secondary-btn">+ Add Practicum</button>
                            </div>
                        </div>
                    </div>

                </div>
            </div>

            <div class="form-card-scrollable" id="form4" style="display: none;">
                <div class="ata-form">
                    
                    <div class="form-row">
                        <div class="form-label">OUTSIDE EMPLOYMENT</div>
                        <div class="form-field" style="align-items: stretch; padding-top: 0;">

                            <div class="employment-header">
                                <div class="employment-col" style="flex:1.5;">University</div>
                                <div class="employment-col">Position</div>
                                <div class="employment-col">Course</div>
                                <div class="employment-col" style="flex:0.5;">Hrs/Wk</div>
                                <div class="employment-col" style="flex:0.5;">Actions</div>
                            </div>

                            <div class="employment-row">
                                <div class="employment-col" style="flex:1.5;"><input type="text" class="table-input" placeholder="Institution Name"></div>
                                <div class="employment-col"><input type="text" class="table-input" placeholder="Role"></div>
                                <div class="employment-col"><input type="text" class="table-input" placeholder="Subject"></div>
                                <div class="employment-col" style="flex:0.5;"><input type="text" class="table-input" placeholder="Hours"></div>
                                <div class="employment-col" style="flex:0.5;"><button type="button" class="action-btn remove-btn"><i class="fas fa-trash"></i></button></div>
                            </div>

                            <div class="add-course-btn" style="padding: 15px 0;">
                                <button type="button" class="secondary-btn">+ Add Employment</button>
                            </div>
                        </div>
                    </div>

                </div>
            </div>

            <div class="form-card-scrollable" id="form5" style="display: none;">
                <div class="ata-form">
                    
                    <div class="form-row">
                        <div class="form-label">REMEDIAL MODULES</div>
                        <div class="form-field" style="align-items: stretch; padding-top: 0;">

                            <div class="remedial-header">
                                <div class="remedial-col">Course ID</div>
                                <div class="remedial-col">Module</div>
                                <div class="remedial-col" style="flex:0.5;">Sec</div>
                                <div class="remedial-col" style="flex:0.5;">Units</div>
                                <div class="remedial-col" style="flex:0.5;">Students</div>
                                
                                <div class="remedial-col">Type</div>
                                
                                <div class="remedial-col" style="flex:0.5;">Actions</div>
                            </div>

                            <div class="remedial-row">
                                <div class="remedial-col"><input type="text" class="table-input" placeholder="ID"></div>
                                <div class="remedial-col">
                                    <select class="table-input" required>
                                        <option value="" disabled selected>Select Module</option>
                                        <option value="M1">M1</option>
                                        <option value="M2">M2</option>
                                        <option value="M3">M3</option>
                                    </select>
                                </div>
                                <div class="remedial-col" style="flex:0.5;"><input type="text" class="table-input" placeholder="#"></div>
                                <div class="remedial-col" style="flex:0.5;">
                                    <select class="table-input" required>
                                        <option value="" disabled selected>0</option>
                                        <option value="1">1</option><option value="2">2</option><option value="3">3</option>
                                        <option value="4">4</option><option value="5">5</option><option value="6">6</option>
                                    </select>
                                </div>
                                <div class="remedial-col" style="flex:0.5;"><input type="text" class="table-input" placeholder="#"></div>
                                
                                <div class="remedial-col">
                                    <select class="table-input type-select" required>
                                        <option value="lecture" selected>Lecture</option>
                                        <option value="lab">Lab</option>
                                    </select>
                                </div>
                                
                                <div class="remedial-col" style="flex:0.5;"><button type="button" class="action-btn remove-btn"><i class="fas fa-trash"></i></button></div>
                            </div>

                            <div class="add-course-btn" style="padding: 15px 0;">
                                <button type="button" class="secondary-btn">+ Add Module</button>
                            </div>
                            <div class="total-units-row" style="margin-top: 20px;">
                                <span>Total Units (G):</span>
                                <span class="total-value">Raw: <span id="localUnitsG">0</span> | Eff: <span id="localEffG">0.00</span></span>
                            </div>

                            <div id="remedialErrorDiv" style="color: #a00100; font-weight: bold; margin-top: 15px; display: none;">
                                <i class="fas fa-exclamation-triangle"></i> ERROR: Maximum limit of 6 effective units exceeded.
                            </div>

                        </div>
                    </div>

                </div>
            </div>

            <div class="form-card-scrollable" id="form6" style="display: none;">
                <div class="ata-form review-form">
                    
                    <div class="form-row">
                        <div class="form-label">SUMMARY</div>
                        <div class="form-field" style="align-items: stretch; padding-top: 0;">

                            <div class="summary-table">
                                <div class="summary-header">
                                    <div class="summary-col section" style="flex:2;">SECTION</div>
                                    <div class="summary-col units">UNITS</div>
                                    <div class="summary-col effective">EFFECTIVE UNITS</div>
                                </div>
                                <div class="summary-row" id="sumRowA" style="display: none;">
                                    <div class="summary-col section" style="flex:2;">(A) Admin Served Units</div><div class="summary-col units">0</div><div class="summary-col effective">N/A</div>
                                </div>
                                <div class="summary-row">
                                    <div class="summary-col section" style="flex:2;">(B) Courses Within College</div><div class="summary-col units" id="sumUnitsB">0</div><div class="summary-col effective" id="sumEffB">0</div>
                                </div>
                                <div class="summary-row">
                                    <div class="summary-col section" style="flex:2;">(C) Courses Other Colleges</div><div class="summary-col units" id="sumUnitsC">0</div><div class="summary-col effective" id="sumEffC">0</div>
                                </div>
                                <div class="summary-row" id="sumRowD" style="display: none;">
                                    <div class="summary-col section" style="flex:2;">(D) Administrative Work</div><div class="summary-col units" id="sumUnitsD">0</div><div class="summary-col effective" id="sumEffD">0</div>
                                </div>
                                <div class="summary-total">
                                    <div class="summary-col section" style="flex:2;">TOTAL REGULAR LOAD</div><div class="summary-col units" id="grandTotalUnits">0</div><div class="summary-col effective" id="grandTotalEff">0</div>
                                </div>
                                <div class="summary-row" style="border-top: 1px solid #eee; margin-top: 10px;">
                                    <div class="summary-col section" style="flex:2;">(G) Remedial Modules</div><div class="summary-col units" id="sumUnitsG">0</div><div class="summary-col effective" id="sumEffG">0</div>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <div class="form-row">
                        <div class="form-label">AGREEMENT</div>
                        <div class="form-field" style="flex-direction: row; gap: 15px; align-items: center;">
                            <input type="checkbox" id="acceptCheckbox" style="width: 18px; height: 18px;">
                            <label for="acceptCheckbox" class="acceptance-label" id="dynamicAcceptLabel">I hereby accept the above teaching assignment/s.</label>
                        </div>
                    </div>

                    <% 
                        // 1. Identify the user's role safely
                        let adminUserRole = (typeof role !== 'undefined' && role) ? role : ((typeof user !== 'undefined' && user && user.role) ? user.role : '');
                        
                        // 2. The Ultimate Signature Hunter (Robust Null Checks)
                        let hasSavedSig = false;
                        let savedSigData = '';
                        
                        if (typeof user !== 'undefined' && user) {
                            if (user.signatureImage && user.signatureImage.length > 20) {
                                hasSavedSig = true;
                                savedSigData = user.signatureImage;
                            } else if (user.signature && user.signature.length > 20) {
                                hasSavedSig = true;
                                savedSigData = user.signature;
                            } else if (user.facultySignature && user.facultySignature.length > 20) {
                                hasSavedSig = true;
                                savedSigData = user.facultySignature;
                            }
                        }
                    %>

                    <div class="form-row e-signature-box" style="border-bottom: none;">
                        <div class="form-label">E-SIGNATURE</div>
                        <div class="form-field" style="align-items: flex-start; flex-direction: column; gap: 10px;">
                            <canvas id="signatureCanvas" width="400" height="150" style="background: #ffffff; border: 1px solid #ccc; border-radius: 4px; cursor: crosshair;"></canvas>
                            <button type="button" id="clearSignatureBtn" class="secondary-btn"><i class="fas fa-eraser"></i> Clear</button>
                        </div>
                    </div>
                    
                    <div class="form-row" style="border-bottom: none;">
                        <div class="form-label"></div>
                        <div class="form-field">
                            <button type="button" id="previewPdfBtn" style="background: #ffffff; color: #444; border: 1px solid #ccc; padding: 10px 20px; border-radius: 4px; cursor: pointer; font-weight: bold;">
                                <i class="fas fa-file-pdf" style="color: #dc3545; margin-right: 8px;"></i> Preview PDF Form
                            </button>
                        </div>
                    </div>

                </div>
            </div>

            <div class="form-card-scrollable" id="form7" style="display: none;">
                <div class="ata-form admin-form">

                    <div class="form-section-header" style="margin-top: 0;">RECOMMENDING APPROVAL</div>

                    <% if (typeof role !== 'undefined' && role === 'Dean') { %>
                        <div style="padding: 30px; text-align: center; color: #555; background: #f8f9fa; border-radius: 8px; margin-top: 20px; border: 1px solid #e0e0e0;">
                            <i class="fas fa-route" style="font-size: 28px; color: var(--color-mapua-blue, #002455); margin-bottom: 15px;"></i>
                            <h3 style="margin: 0 0 10px 0; color: #333;">Hello, Dean.</h3>
                            <p style="margin: 0; font-size: 14px; line-height: 1.5;">
                                Your teaching assignment will be routed to the <strong>Program Chair</strong> for initial review.<br><br>
                                If an overload is detected on your load, the Program Chair will provide the official justification during their endorsement. You may bypass this section and submit your form.
                            </p>
                        </div>
                        <textarea id="justificationText" name="justification" style="display:none;"></textarea>
                    <% } else { %>
                        <div class="form-row justification-row" style="border: none;">
                            <div class="form-label" style="line-height: 1.4;">OVERLOAD JUSTIFICATION<br><span style="font-size: 9px; font-weight: normal;">(IF APPLICABLE)</span></div>
                            <div class="form-field">
                                <textarea class="form-input" id="justificationText" name="justification" rows="4" style="max-width: 100% !important; color: #333333 !important; background-color: #ffffff !important; font-size: 14px !important;"></textarea>
                            </div>
                        </div>
                    <% } %>

                </div>
            </div>

        </div>

    </main>

    <div class="form-navigation-outside"></div>

    <script>
        window.DRAFT_FORM_DATA = <%- typeof form !== 'undefined' && form ? JSON.stringify(form) : 'null' %>;
    </script>
    <script src="/ATA/js/ata_client.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/signature_pad@4.1.5/dist/signature_pad.umd.min.js"></script>
    <script src="/ATA/js/new-ata.js"></script>
</body>
</html>