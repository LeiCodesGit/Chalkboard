<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Review Form: <%= form.facultyName %></title>
    <link rel="stylesheet" href="/ATA/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        /* Forces the page to take up exactly 100% of the screen height without scrolling the whole body */
        body { margin: 0; overflow: hidden; background: #1a1a1a; }
        
        /* The container holding the PDF */
        .pdf-container {
            height: calc(100vh - 90px); /* Leaves 90px for the action bar */
            width: 100%;
        }

        /* The Sticky Action Bar at the bottom */
        .sticky-action-bar {
            height: 90px;
            background: #222;
            border-top: 4px solid #b30000; /* Mapua Red */
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0 40px;
            box-shadow: 0 -4px 10px rgba(0,0,0,0.5);
        }
    </style>
</head>
<body data-role="<%= typeof role !== 'undefined' ? role : 'Admin' %>" 
      data-employment="<%= (typeof user !== 'undefined' && user.employmentType) ? user.employmentType : 'Full-Time' %>"
      data-practicum="<%= (typeof user !== 'undefined' && user.isPracticumCoordinator) ? 'true' : 'false' %>"
      data-has-practicum="<%= typeof hasPracticum !== 'undefined' ? hasPracticum : 'false' %>"
      data-status="<%= form.status %>">
    <%- include('../partials/sideMenuBar') %> 

    <main style="margin-left: 260px; width: calc(100vw - 260px); display: flex; flex-direction: column;">
        
        <div class="pdf-container">
            <iframe src="/ata/pdf/<%= form._id %>" width="100%" height="100%" style="border: none;"></iframe>
        </div>

        <div class="sticky-action-bar">
            
            <div style="color: white; font-size: 16px;">
                <strong>Reviewing:</strong> <%= form.facultyName %> | <strong>Status:</strong> <span style="color: #ffc107;"><%= form.status %></span>
            </div>

            <div style="display: flex; gap: 15px; align-items: center;">
                <input type="text" id="adminRemarks" placeholder="Enter remarks/justification..." 
                       style="padding: 10px 15px; border-radius: 5px; border: none; width: 350px; background: #333; color: white;">
                
                <button class="form-btn" id="btnReturn" style="background: #dc3545; color: white; border: none; padding: 10px 20px;">
                    <i class="fas fa-undo"></i> Return
                </button>
                
                <button class="form-btn" id="btnApprove" style="background: #28a745; color: white; border: none; padding: 10px 20px;">
                    <i class="fas fa-check"></i> Endorse / Approve
                </button>
            </div>

        </div>

    </main>
    
    <script src="/ATA/js/ata_client.js"></script>
</body>
</html>